# Maintainer: Rafael Alves <rafael1020alvessantos@gmail.com>
pkgname=noteos-keyring
pkgver=0.0.1
pkgrel=1
pkgdesc="Keyring placeholder for NoteOs"
arch=('any')
url="https://github.com/rafael1020alvessantos/NoteOs"
license=('MIT')
package() {
  mkdir -p "$pkgdir/usr/share/pacman/keyrings"
  touch "$pkgdir/usr/share/pacman/keyrings/noteos.gpg"
  touch "$pkgdir/usr/share/pacman/keyrings/noteos-trusted"
  touch "$pkgdir/usr/share/pacman/keyrings/noteos-revoked"
}
